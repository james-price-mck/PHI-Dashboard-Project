{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/phi-dashboard.schema.json",
  "title": "PHI Australia dashboard bundle",
  "type": "object",
  "required": ["meta", "reconciliation", "national_quarterly", "jurisdiction_quarterly", "hospital_by_age_quarterly"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["etl_build_time_utc", "source_file"],
      "properties": {
        "data_as_of": { "type": ["string", "null"] },
        "etl_build_time_utc": { "type": "string" },
        "source_file": { "type": "string" },
        "apra_methodology_change_iso": { "type": "string" },
        "pop_denominator_note": { "type": "string" },
        "hospital_vs_general_note": { "type": "string" },
        "tier_note": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reconciliation": {
      "type": "object",
      "required": ["passed", "metric", "message", "tolerance"],
      "properties": {
        "passed": { "type": "boolean" },
        "metric": { "type": "string" },
        "expected": { "type": ["number", "null"] },
        "actual": { "type": ["number", "null"] },
        "abs_diff": { "type": ["number", "null"] },
        "tolerance": { "type": "number" },
        "message": { "type": "string" }
      }
    },
    "national_quarterly": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quarter", "hospital_treatment", "general_treatment"],
        "properties": {
          "quarter": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "hospital_treatment": { "$ref": "#/$defs/treatmentBlock" },
          "general_treatment": { "$ref": "#/$defs/treatmentBlock" }
        }
      }
    },
    "jurisdiction_quarterly": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quarter", "jurisdictions"],
        "properties": {
          "quarter": { "type": "string" },
          "jurisdictions": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "share_of_population": { "type": ["number", "null"] },
                "insured_persons": { "type": ["number", "null"] },
                "population_denominator": { "type": ["number", "null"] }
              }
            }
          }
        }
      }
    },
    "hospital_by_age_quarterly": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["quarter", "hospital_insured_by_age_band"],
        "properties": {
          "quarter": { "type": "string" },
          "hospital_insured_by_age_band": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          }
        }
      }
    }
  },
  "$defs": {
    "treatmentBlock": {
      "type": "object",
      "required": ["insured_persons", "share_of_population", "population_denominator"],
      "properties": {
        "insured_persons": { "type": ["number", "null"] },
        "share_of_population": { "type": ["number", "null"] },
        "population_denominator": { "type": ["number", "null"] }
      }
    }
  }
}
